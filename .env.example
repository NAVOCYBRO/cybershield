# CyberShield Configuration
# Copy this file to .env and add your API keys

# Groq API Key (get free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key (get free at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Flask Configuration
SECRET_KEY=your-secret-key-for-flask-session
DEBUG=True
PORT=5000

# Optional: NVD API Key for CVE lookups (get free at https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=your_nvd_api_key_here
